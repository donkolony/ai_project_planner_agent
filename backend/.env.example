APP_NAME=AI Project Planner Agent
ENVIRONMENT=development
DEBUG=false

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Database Configuration
# Local development: sqlite:///./plans.db
# Azure SQL: mssql+pyodbc://user:password@server.database.windows.net/database?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=sqlite:///./plans.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173